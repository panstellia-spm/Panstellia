rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid))
        .data.get('isAdmin', false) == true;
    }

    // Check if user email is in admin list (for free tier)
    function isAdminEmail() {
      return request.auth != null && request.auth.token.email in [
        'support@panstellia.com',
        'admin@panstellia.com'
      ];
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, update, delete: if isOwner(userId);
      allow create: if isOwner(userId) &&
        request.resource.data.keys().hasAll(['email', 'createdAt']);
    }

    match /products/{productId} {
      allow read: if true;
      // Allow write if user is admin in document OR has admin email (free tier)
      allow write: if isAdmin() || isAdminEmail();
    }

    match /carts/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /wishlist/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /orders/{orderId} {
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;

      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid || isAdmin() || isAdminEmail());

      allow update: if isAdmin() || isAdminEmail();
    }

    // Razorpay payments persisted by Firebase Functions.
    // Users generally should not write to this collection.
    match /payments/{paymentId} {
      allow read: if request.auth != null &&
        // Allow admins to read.
        (isAdmin() || isAdminEmail());

      // Writes are server-only. Enforce by denying all client writes.
      allow create, update, delete: if false;
    }


    match /{document=**} {
      allow read, write: if false;
    }
  }
}
