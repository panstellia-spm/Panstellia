rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───────────────────────────────────────────────────

    // Check if user email is in the admin whitelist (for Spark-tier compatibility)
    function isAdminEmail() {
      return request.auth != null && request.auth.token.email in [
        'support@panstellia.com',
        'admin@panstellia.com'
      ];
    }

    // Get the user's role from their document, default to 'user'
    function getRole() {
      return request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user')
        : 'user';
    }

    // Verify if user has one of the required roles (or is whitelisted admin)
    function hasRole(roles) {
      return request.auth != null && (
        getRole() in roles || isAdminEmail()
      );
    }

    // Checking legacy isAdmin flag or email for backward compatibility
    function isAdminUser() {
      return isAdminEmail() || 
        (request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true) ||
        hasRole(['super_admin', 'admin']);
    }

    // Check if requesting user owns the resource
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // ─── Users Collection ───────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId) || hasRole(['super_admin', 'admin', 'content_manager', 'inventory_manager', 'marketing_manager', 'customer_support', 'viewer']);
      
      // Enforce that only super_admin can modify the role field, and users cannot self-escalate
      allow update: if isOwner(userId) && (
        // Non-super-admins cannot alter their role
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isAdmin'])) ||
        hasRole(['super_admin'])
      );
      
      allow delete: if isOwner(userId) || hasRole(['super_admin']);
      allow create: if isOwner(userId) &&
        request.resource.data.keys().hasAll(['email', 'createdAt']) &&
        // New users default to 'user' role
        request.resource.data.get('role', 'user') == 'user';
    }

    // ─── Products Collection ────────────────────────────────────────────────
    match /products/{productId} {
      allow read: if true; // Public read
      allow write: if hasRole(['super_admin', 'admin', 'content_manager', 'inventory_manager']);
      
      // Allow customers to decrement stock during checkout transactions
      allow update: if request.auth != null &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'stockQuantity', 'reservedQuantity', 'availableQuantity', 
          'inventoryStatus', 'lastStockUpdate', 'stockUpdatedBy', 'inventoryValue',
          'archived', 'archivedAt' // allow soft-delete updates if authorized
        ]) &&
        request.resource.data.price == resource.data.price &&
        request.resource.data.name == resource.data.name &&
        request.resource.data.stockQuantity <= resource.data.stockQuantity &&
        request.resource.data.reservedQuantity >= 0 &&
        request.resource.data.availableQuantity == request.resource.data.stockQuantity - request.resource.data.reservedQuantity;
    }

    // ─── Orders Collection ──────────────────────────────────────────────────
    match /orders/{orderId} {
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid || hasRole(['super_admin', 'admin', 'customer_support', 'viewer']));
      allow update: if hasRole(['super_admin', 'admin', 'customer_support']) ||
        (isOwner(resource.data.userId) && resource.data.status == 'pending_payment' &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['couponCode', 'couponDiscount']));
      allow delete: if hasRole(['super_admin', 'admin']);
    }

    // ─── Payments Collection ────────────────────────────────────────────────
    match /payments/{paymentId} {
      allow read: if hasRole(['super_admin', 'admin', 'viewer']);
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if false; // Immutable
    }

    // ─── Carts Collection ───────────────────────────────────────────────────
    match /carts/{userId} {
      allow read: if isOwner(userId) || hasRole(['super_admin', 'admin', 'customer_support', 'viewer']);
      allow write: if isOwner(userId);
    }

    // ─── Wishlist Collection ─────────────────────────────────────────────────
    match /wishlist/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ─── Activity Logs Collection ─────────────────────────────────────────────
    match /activity_logs/{logId} {
      allow read: if hasRole(['super_admin', 'admin']);
      allow create: if hasRole(['super_admin', 'admin', 'content_manager', 'inventory_manager', 'marketing_manager', 'customer_support']);
      allow update, delete: if false; // Immutable
    }

    // ─── Inventory Logs Collection ───────────────────────────────────────────
    match /inventory_logs/{logId} {
      allow read: if hasRole(['super_admin', 'admin', 'inventory_manager', 'viewer']);
      allow create: if request.auth != null; // Checkout or admin
      allow update, delete: if false; // Immutable
    }

    // ─── Customer Feedback Collection ────────────────────────────────────────
    match /customerFeedback/{feedbackId} {
      allow create: if true; // Public contact form
      allow read: if hasRole(['super_admin', 'admin', 'customer_support', 'viewer']);
      allow update, delete: if false; // Immutable
    }

    // ─── Order Notes Collection ───────────────────────────────────────────────
    match /order_notes/{noteId} {
      allow read: if hasRole(['super_admin', 'admin', 'customer_support', 'viewer']);
      allow create: if hasRole(['super_admin', 'admin', 'customer_support']);
      allow update: if false;
      allow delete: if hasRole(['super_admin', 'admin']);
    }

    // ─── Fulfillment Logs Collection ──────────────────────────────────────────
    match /fulfillmentLogs/{logId} {
      allow read: if hasRole(['super_admin', 'admin', 'inventory_manager', 'customer_support', 'viewer']);
      allow create: if hasRole(['super_admin', 'admin', 'inventory_manager', 'customer_support']);
      allow update, delete: if false;
    }

    // ─── Shipments Collection ─────────────────────────────────────────────────
    match /shipments/{shipmentId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || hasRole(['super_admin', 'admin', 'inventory_manager', 'customer_support', 'viewer']));
      allow create: if hasRole(['super_admin', 'admin', 'inventory_manager', 'customer_support']);
      allow update: if hasRole(['super_admin', 'admin', 'inventory_manager', 'customer_support']);
      allow delete: if false;
    }

    // ─── Back In Stock Notifications Collection ─────────────────────────────
    match /back_in_stock_notifications/{notificationId} {
      allow read, create: if true;
      allow update, delete: if hasRole(['super_admin', 'admin', 'inventory_manager']);
    }

    // ─── Admin Notifications Collection ──────────────────────────────────────
    match /admin_notifications/{notificationId} {
      allow read, delete: if hasRole(['super_admin', 'admin', 'inventory_manager', 'customer_support']);
      allow create: if request.auth != null;
      allow update: if hasRole(['super_admin', 'admin', 'inventory_manager', 'customer_support']) && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
    }

    // ─── New Commerce Transformation Collections ─────────────────────────────

    // System Settings (payments, CMS info, active filters)
    match /system_settings/{settingId} {
      allow read: if true; // Publicly readable for checkout/navbar
      allow write: if hasRole(['super_admin', 'admin']);
    }

    // Shipping Settings (threshold, standard charge, status toggles)
    match /ShippingSettings/{settingId} {
      allow read: if true; // Publicly readable for checkout calculation
      allow write: if hasRole(['super_admin', 'admin']); // Restricted to admin roles
    }

    // Settings history versions
    match /settings_history/{historyId} {
      allow read: if hasRole(['super_admin', 'admin']);
      allow create: if hasRole(['super_admin', 'admin']);
      allow update, delete: if false;
    }

    // Homepage layout documents (active, draft)
    match /homepage_layout/{layoutId} {
      allow read: if true; // Publicly readable
      allow write: if hasRole(['super_admin', 'admin', 'content_manager']);
    }

    // Homepage layout history versions
    match /homepage_history/{historyId} {
      allow read: if hasRole(['super_admin', 'admin', 'content_manager']);
      allow create: if hasRole(['super_admin', 'admin', 'content_manager']);
      allow update, delete: if false;
    }

    // Landing Pages
    match /landing_pages/{pageId} {
      allow read: if true; // Publicly readable
      allow write: if hasRole(['super_admin', 'admin', 'content_manager', 'marketing_manager']);
    }

    // Offers and coupons
    match /offers/{offerId} {
      allow read: if true; // Publicly readable for coupon validation
      allow write: if hasRole(['super_admin', 'admin', 'marketing_manager']);
    }

    // Product reviews and moderation queue
    match /reviews/{reviewId} {
      allow read: if true; // Public read of approved reviews
      allow create: if true; // Public write to submit reviews
      allow update: if hasRole(['super_admin', 'admin', 'content_manager', 'customer_support']);
      allow delete: if hasRole(['super_admin', 'admin']);
    }

    // Custom Collections metadata
    match /collections_metadata/{collectionId} {
      allow read: if true; // Public
      allow write: if hasRole(['super_admin', 'admin', 'content_manager']);
    }

    // Warranty Templates
    match /warranties/{warrantyId} {
      allow read: if true; // Publicly readable
      allow write: if hasRole(['super_admin', 'admin', 'content_manager']);
    }

    // Warranty Assignments mapping rules
    match /warranty_assignments/{assignmentId} {
      allow read: if true; // Publicly readable
      allow write: if hasRole(['super_admin', 'admin', 'content_manager']);
    }

    // Warranty History audit logs
    match /warranty_history/{historyId} {
      allow read: if hasRole(['super_admin', 'admin', 'content_manager']);
      allow create: if hasRole(['super_admin', 'admin', 'content_manager']);
      allow update, delete: if false; // Immutable
    }

    // ─── Default: Deny Everything Else ──────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
