rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───────────────────────────────────────────────────

    // Check if user is admin via Firestore user document
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid))
        .data.get('isAdmin', false) == true;
    }

    // Check if user email is in the admin whitelist (for Spark-tier compat)
    function isAdminEmail() {
      return request.auth != null && request.auth.token.email in [
        'support@panstellia.com',
        'admin@panstellia.com'
      ];
    }

    // Combined admin check
    function isAdminUser() {
      return isAdmin() || isAdminEmail();
    }

    // Check if requesting user owns the resource
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // ─── Users Collection ───────────────────────────────────────────────────
    match /users/{userId} {
      // Users can read/update their own doc; admins can read all
      allow read: if isOwner(userId) || isAdminUser();
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId) || isAdminUser();
      // Create only if authenticated and owns the document
      allow create: if isOwner(userId) &&
        request.resource.data.keys().hasAll(['email', 'createdAt']);
    }

    // ─── Products Collection ────────────────────────────────────────────────
    match /products/{productId} {
      // Anyone (including unauthenticated) can read products
      allow read: if true;
      // Only admins can create, update, delete products
      allow write: if isAdminUser();
      
      // Customers can update stock fields during checkout
      allow update: if request.auth != null &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'stockQuantity', 'reservedQuantity', 'availableQuantity', 
          'inventoryStatus', 'lastStockUpdate', 'stockUpdatedBy', 'inventoryValue'
        ]) &&
        request.resource.data.price == resource.data.price &&
        request.resource.data.name == resource.data.name &&
        request.resource.data.stockQuantity <= resource.data.stockQuantity &&
        request.resource.data.reservedQuantity >= 0 &&
        request.resource.data.availableQuantity == request.resource.data.stockQuantity - request.resource.data.reservedQuantity;
    }

    // ─── Orders Collection ──────────────────────────────────────────────────
    match /orders/{orderId} {
      // Users can create their own orders
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;

      // Users can read their own orders; admins can read all
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid || isAdminUser());

      // Only admins can update (status changes) or delete orders
      allow update: if isAdminUser();
      allow delete: if isAdminUser();
    }

    // ─── Payments Collection ────────────────────────────────────────────────
    match /payments/{paymentId} {
      // Only admins can read all payments
      allow read: if isAdminUser();

      // Users can create their own payment records (client-side after Razorpay)
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;

      // No one can update or delete payment records for integrity
      allow update, delete: if false;
    }

    // ─── Carts Collection ───────────────────────────────────────────────────
    match /carts/{userId} {
      // Users own their cart; admins can read carts for analytics
      allow read: if isOwner(userId) || isAdminUser();
      allow write: if isOwner(userId);
    }

    // ─── Wishlist Collection ─────────────────────────────────────────────────
    match /wishlist/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ─── Activity Logs Collection ─────────────────────────────────────────────
    match /activity_logs/{logId} {
      // Only admins can read logs
      allow read: if isAdminUser();
      // Admins can create log entries (client-side logging)
      allow create: if isAdminUser() &&
        request.resource.data.keys().hasAll(['timestamp', 'module', 'action', 'description', 'status']);
      // Logs are immutable — no updates or deletes
      allow update, delete: if false;
    }

    // ─── Inventory Logs Collection ───────────────────────────────────────────
    match /inventory_logs/{logId} {
      // Only admins can read inventory logs
      allow read: if isAdminUser();
      // Admins and authenticated checkouts can create logs
      allow create: if request.auth != null &&
        request.resource.data.keys().hasAll(['productId', 'productName', 'action', 'change', 'previousValue', 'newValue', 'adminId', 'timestamp']);
      // Logs are immutable
      allow update, delete: if false;
    }

    // ─── Customer Feedback Collection ────────────────────────────────────────
    match /customerFeedback/{feedbackId} {
      // Anyone can create feedback (no auth required)
      allow create: if true;
      // Only admins can read feedback
      allow read: if isAdminUser();
      // No updates or deletes allowed
      allow update, delete: if false;
    }

    // ─── Order Notes Collection ───────────────────────────────────────────────
    // Internal admin notes per order
    match /order_notes/{noteId} {
      // Only admins can read, create, delete notes
      allow read: if isAdminUser();
      allow create: if isAdminUser() &&
        request.resource.data.keys().hasAll(['orderId', 'note', 'adminId', 'adminName', 'createdAt']);
      // Notes are immutable after creation
      allow update: if false;
      allow delete: if isAdminUser();
    }

    // ─── Fulfillment Logs Collection ──────────────────────────────────────────
    match /fulfillmentLogs/{logId} {
      allow read: if isAdminUser();
      allow create: if isAdminUser() &&
        request.resource.data.keys().hasAll(['orderId', 'adminId', 'adminName', 'action', 'timestamp']);
      allow update, delete: if false;
    }

    // ─── Shipments Collection ─────────────────────────────────────────────────
    match /shipments/{shipmentId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdminUser());
      allow create: if isAdminUser() &&
        request.resource.data.keys().hasAll(['orderId', 'userId', 'courierName', 'trackingNumber', 'shippedAt']);
      allow update: if isAdminUser();
      allow delete: if false;
    }

    // ─── Default: Deny Everything Else ──────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
