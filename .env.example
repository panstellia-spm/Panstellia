# Vite environment variables (frontend)

# Razorpay checkout public key (safe for frontend)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxx

# Firebase Functions REST endpoints (call these from frontend)
# Example:
# VITE_FIREBASE_CREATE_ORDER_URL=https://us-central1-YOUR_PROJECT.cloudfunctions.net/createOrder
# VITE_FIREBASE_VERIFY_PAYMENT_URL=https://us-central1-YOUR_PROJECT.cloudfunctions.net/verifyPayment
VITE_FIREBASE_CREATE_ORDER_URL=https://YOUR_REGION-YOUR_PROJECT.cloudfunctions.net/createOrder
VITE_FIREBASE_VERIFY_PAYMENT_URL=https://YOUR_REGION-YOUR_PROJECT.cloudfunctions.net/verifyPayment

