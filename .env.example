# Razorpay Configuration
# Get these from https://dashboard.razorpay.com/app/settings/keys

# Test Key ID (use this prefix for testing)
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id_here

# Note: RAZORPAY_KEY_SECRET is server-side only
# Configure this in Netlify Dashboard > Site Settings > Environment Variables
# Do NOT prefix with VITE_ for server-side variables
RAZORPAY_KEY_SECRET=your_key_secret_here
